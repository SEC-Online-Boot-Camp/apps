# --- LLMの切り替え -------------------------------------------
LLM_PROVIDER=openai  # openai / azure

# --- OpenAI API ---
OPENAI_API_KEY=<あなたのAPIキー>
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small  # 埋め込みモデル(通常は変更不要)

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<あなたのリソース名>.openai.azure.com
AZURE_OPENAI_API_KEY=<あなたのAPIキー>
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# --- 読み込みフォルダ ---
DOCS_DIR=./documents

# --- 詳細設定（通常は変更不要）---
LLM_TEMPERATURE=0.2       # 生成AIの温度（0.0〜1.0、低いほど安定した回答）
RAG_CHUNK_SIZE=200        # チャンク分割の文字数
RAG_OVERLAP=40            # チャンク間のオーバーラップ文字数
# FLASK_DEBUG=true        # デバッグモードを有効にする場合はコメントを外す
